// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/ubuntu
{
	"name": "Ubuntu",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	// "image": "mcr.microsoft.com/devcontainers/base:noble"
	"dockerFile": "Dockerfile",
	// first enable nvidia runtime using instructions from here https://docs.nvidia.com/datacenter/cloud-native/container-toolkit/latest/install-guide.html#docker
	// then verify by running docker run --rm --runtime=nvidia --gpus all nvidia/cuda:11.6.2-base-ubuntu20.04 nvidia-smi on the host
	"runArgs": [
		"--gpus",
		"all"
	],
	"containerEnv": {
		// if you run unsloth for RL/Fine-tuning workloads, this is currently required due to some kind of timing issue with the driver loading
		"CUDA_MODULE_LOADING": "EAGER"
	},
	// Features to add to the dev container. More info: https://containers.dev/features.
	"features": {
		"ghcr.io/devcontainers/features/node:1": {},
		"ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
		"ghcr.io/devcontainers/features/github-cli:1": {}
	},
	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],
	"mounts": [
		// if your ssh keys are on windows, to be able to commit ensure ssh-agent service is running on host: PS:> Start-Service ssh-agent and add your keys: PS:> ssh-add ~/.ssh/id_ed25519
		// mount .ssh directory from host to gain access to your ssh keys
		"source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached",
		// Persist bash history from host
		"source=${localEnv:HOME}/.bash_history,target=/home/vscode/.bash_history,type=bind",
		"source=claude-code-config,target=/home/node/.claude,type=volume"
	],
	// Use 'postCreateCommand' to run commands after vscode is attached to the running container.
	"postCreateCommand": {
		// "git": "git config user.name 'Dev Containerinen' && git config user.email 'dev.containerinen@solita.fi'"
	},
	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-toolsai.jupyter",
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-python.black-formatter",
				"GitHub.copilot-chat",
				"Anthropic.claude-code"
			]
		}
	}
	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
